# Backend Environment Variables
# Copy this file to .env for local development
# Set these as environment variables in your hosting platform (Render, Railway, etc.)

# --- Server ---
PORT=5000

# --- Database (MySQL) ---
# For local development: use your local MySQL credentials
# For production: use credentials from PlanetScale, Aiven, or your cloud MySQL provider
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=habit_tracker

# --- JWT Authentication ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# --- CORS ---
# Set to your deployed Vercel frontend URL in production
# Example: https://habit-tracker-xyz.vercel.app
FRONTEND_URL=http://localhost:5173
